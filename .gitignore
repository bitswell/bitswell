# OS
.DS_Store
Thumbs.db

# Editor
# (Patterns without trailing slash so they match sandbox char-device bind-mounts as well as real dirs)
*.swp
*.swo
*~
.vscode
.idea

# Node (if ever needed)
node_modules/

# Environment
.env
.env.local

# Run logs
.runs/

# Rust build artifacts
**/target/

# Worktrees (legacy layout)
.worktrees/

# Agent runtime state
.loom/

# Claude session logs
.claude/bitswell/

# Sandbox home-file bind mounts (appear as /dev/null char devices in sandbox)
/.bash_profile
/.bashrc
/.profile
/.zshrc
/.zprofile
/.gitconfig
/.ripgreprc

# Claude runtime / sandbox mounts at top-level
/.claude/commands
/.claude/skills
/.claude/agent-memory/
/.claude/*.lock
/.mcp.json
/.playwright-mcp/

# tasks/*.md are protocol artifacts (see tasks/README.md) — they ARE tracked.
# Coordinator agents (bitswell, vesper) must write them from a worktree+PR,
# not in the primary checkout. See CLAUDE.md "Development Workflow".
