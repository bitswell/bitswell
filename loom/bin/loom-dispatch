#!/usr/bin/env bash
# loom-dispatch -- Detect ASSIGNED commits and spawn agents.
#
# Usage:
#   loom-dispatch [--commit <sha>] [--branch <branch>] [--dry-run]
#   loom-dispatch --scan [--dry-run]
#
# Modes:
#   --commit SHA    Check a specific commit for ASSIGNED trailers and dispatch.
#   --branch NAME   Check the tip of a specific branch.
#   --scan          Scan all loom/* branches for undispatched assignments.
#   --dry-run       Print what would happen without spawning.
#
# Environment:
#   LOOM_SPAWN_CMD  Command to spawn an agent. Receives prompt on stdin.
#                   Default: loom-spawn (sibling script)
#
# Requirements: git

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
GIT_DIR="$(git rev-parse --git-common-dir)"
LOOM_DIR="$GIT_DIR/loom"
SPAWN_CMD="${LOOM_SPAWN_CMD:-$SCRIPT_DIR/loom-spawn}"

MODE=""
TARGET_COMMIT=""
TARGET_BRANCH=""
DRY_RUN=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --commit)  MODE="commit";  TARGET_COMMIT="$2"; shift 2 ;;
    --branch)  MODE="branch";  TARGET_BRANCH="$2"; shift 2 ;;
    --scan)    MODE="scan";    shift ;;
    --dry-run) DRY_RUN=true;   shift ;;
    -h|--help) sed -n '2,/^$/{ s/^# //; s/^#//; p }' "$0"; exit 0 ;;
    *) echo "Unknown option: $1" >&2; exit 1 ;;
  esac
done

[[ -z "$MODE" ]] && { echo "Error: specify --commit, --branch, or --scan" >&2; exit 1; }

# --- trailer extraction ---

trailer_value() {
  local sha="$1" key="$2"
  git log -1 --format="%(trailers:key=$key,valueonly)" "$sha" | head -1 | xargs
}

is_assignment_commit() {
  [[ "$(trailer_value "$1" "Task-Status")" == "ASSIGNED" ]]
}

extract_assignment() {
  local sha="$1"
  AGENT_ID="$(trailer_value "$sha" "Assigned-To")"
  ASSIGNMENT_ID="$(trailer_value "$sha" "Assignment")"
  SCOPE="$(trailer_value "$sha" "Scope")"
  DEPENDENCIES="$(trailer_value "$sha" "Dependencies")"
  BUDGET="$(trailer_value "$sha" "Budget")"
  SESSION_ID="$(trailer_value "$sha" "Session-Id")"
}

# --- worktree lookup ---

find_worktree_for_branch() {
  local branch="$1"
  git worktree list --porcelain | awk -v branch="refs/heads/$branch" '
    /^worktree / { wt = substr($0, 10) }
    /^branch / && $2 == branch { print wt; exit }
  '
}

# --- dependency helpers ---

dep_to_branch() {
  local dep="$1"
  echo "loom/${dep//\//-}"
}

check_dependencies() {
  local deps="$1"
  [[ "$deps" == "none" || -z "$deps" ]] && return 0
  local IFS=','
  for dep in $deps; do
    dep="$(echo "$dep" | xargs)"
    local branch_name
    branch_name="$(dep_to_branch "$dep")"
    if git rev-parse --verify "$branch_name" >/dev/null 2>&1; then
      local s
      s="$(git log -1 --format='%(trailers:key=Task-Status,valueonly)' --grep='Task-Status:' "$branch_name" 2>/dev/null | head -1 | xargs)"
      [[ "$s" == "COMPLETED" ]] && continue
    fi
    echo "Dep not met: $dep (branch: $branch_name)" >&2
    return 1
  done
  return 0
}

# --- idempotency ---

lock_dir_path() {
  echo "$LOOM_DIR/locks/$1/$2.lock.d"
}

is_dispatched() {
  [[ -d "$(lock_dir_path "$1" "$2")" ]]
}

# Atomically claim a lock directory. Returns 1 if already claimed.
# mkdir(2) is atomic on all POSIX filesystems; file write is not.
try_lock() {
  local lock_dir
  lock_dir="$(lock_dir_path "$1" "$2")"
  mkdir -p "$LOOM_DIR/locks/$1"
  mkdir "$lock_dir" 2>/dev/null
}

write_lock_info() {
  local pid="$1" agent="$2" assignment="$3"
  printf 'pid=%s\ndispatched=%s\n' "$pid" "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    > "$(lock_dir_path "$agent" "$assignment")/info"
}

# --- dispatch ---

dispatch_agent() {
  local sha="$1" branch="${2:-}"
  extract_assignment "$sha"
  [[ -z "$AGENT_ID" ]] && { echo "Error: no Assigned-To in $sha" >&2; return 1; }

  local worktree=""
  [[ -n "$branch" ]] && worktree="$(find_worktree_for_branch "$branch")" || true

  echo "--- Dispatch ---"
  echo "  Commit:       $sha"
  echo "  Agent:        $AGENT_ID"
  echo "  Assignment:   $ASSIGNMENT_ID"
  echo "  Scope:        $SCOPE"
  echo "  Dependencies: $DEPENDENCIES"
  echo "  Budget:       $BUDGET"
  [[ -n "$worktree" ]] && echo "  Worktree:     $worktree" || echo "  Worktree:     (not found)"

  if is_dispatched "$AGENT_ID" "$ASSIGNMENT_ID"; then
    echo "  SKIP: already dispatched (lock: $(lock_dir_path "$AGENT_ID" "$ASSIGNMENT_ID"))"
    return 0
  fi

  check_dependencies "$DEPENDENCIES" || { echo "  BLOCKED on deps" >&2; return 1; }
  echo "  Dependencies: OK"

  if [[ "$DRY_RUN" == "true" ]]; then
    echo "  [DRY RUN] Would spawn $AGENT_ID"
    return 0
  fi

  [[ -z "$worktree" ]] && { echo "  ERROR: No worktree for branch '$branch'" >&2; return 1; }

  local task_body
  task_body="$(git log -1 --format='%B' "$sha")"

  local prompt_file
  prompt_file="$(mktemp)"
  # No trap here — loom-spawn owns the prompt file from this point and cleans it up.

  cat > "$prompt_file" <<'PROMPT'
You are __AGENT_ID__. Your assignment is __ASSIGNMENT_ID__.
Your working directory is this git checkout. Use git commands normally.
Your task (from the ASSIGNED commit):

__TASK_BODY__

Commit protocol:
- Every commit: Agent-Id: __AGENT_ID__, Session-Id: __SESSION_ID__
- First commit: Task-Status: IMPLEMENTING
- Final commit: Task-Status: COMPLETED with Key-Finding trailer(s)
PROMPT

  sed -i "s|__AGENT_ID__|${AGENT_ID}|g" "$prompt_file"
  sed -i "s|__ASSIGNMENT_ID__|${ASSIGNMENT_ID}|g" "$prompt_file"
  sed -i "s|__SESSION_ID__|${SESSION_ID}|g" "$prompt_file"

  # Replace __TASK_BODY__ with the actual task body (handles multiline + special chars).
  local body_file
  body_file="$(mktemp)"
  printf '%s' "$task_body" > "$body_file"
  awk -v placeholder="__TASK_BODY__" -v bodyfile="$body_file" '
    $0 ~ placeholder {
      while ((getline line < bodyfile) > 0) print line
      close(bodyfile)
      next
    }
    { print }
  ' "$prompt_file" > "${prompt_file}.tmp"
  mv "${prompt_file}.tmp" "$prompt_file"
  rm -f "$body_file"

  echo "  Prompt: $prompt_file"
  echo "  Spawning via: $SPAWN_CMD"
  echo "  PWD: $worktree"

  # Claim lock atomically before spawning. Prevents concurrent double-dispatch.
  if ! try_lock "$AGENT_ID" "$ASSIGNMENT_ID"; then
    echo "  SKIP: already dispatched (lock claimed concurrently)"
    return 0
  fi

  (cd "$worktree" && "$SPAWN_CMD" "$prompt_file") &
  local spawn_pid=$!
  echo "  PID: $spawn_pid"

  write_lock_info "$spawn_pid" "$AGENT_ID" "$ASSIGNMENT_ID"
  echo "  Agent $AGENT_ID dispatched."
}

dispatch_commit() {
  local sha="$1"
  is_assignment_commit "$sha" || { echo "$sha is not ASSIGNED" >&2; return 1; }
  local branch
  branch="$(git branch --contains "$sha" --format='%(refname:short)' 2>/dev/null | grep '^loom/' | head -1)" || true
  dispatch_agent "$sha" "$branch"
}

case "$MODE" in
  commit) dispatch_commit "$TARGET_COMMIT" ;;
  branch)
    sha="$(git log -1 --format='%H' --grep='Task-Status: ASSIGNED' "$TARGET_BRANCH" 2>/dev/null)"
    [[ -z "$sha" ]] && { echo "No ASSIGNED commit on $TARGET_BRANCH" >&2; exit 1; }
    dispatch_agent "$sha" "$TARGET_BRANCH"
    ;;
  scan)
    echo "Scanning loom/* branches..."
    found=0
    while read -r branch; do
      s="$(git log -1 --format='%(trailers:key=Task-Status,valueonly)' --grep='Task-Status:' "$branch" 2>/dev/null | head -1 | xargs)"
      if [[ "$s" == "ASSIGNED" ]]; then
        sha="$(git log -1 --format='%H' --grep='Task-Status: ASSIGNED' "$branch" 2>/dev/null)"
        echo ""; echo "Found: $branch"
        dispatch_agent "$sha" "$branch" || true
        found=$((found + 1))
      fi
    done < <(git branch --list 'loom/*' --format='%(refname:short)' 2>/dev/null)
    [[ "$found" -eq 0 ]] && echo "None found." || echo "Dispatched $found."
    ;;
esac
